{
  "name": "lattes2orcid",
  "version": "1.0.0",
  "private": true,
  "description": "Lattes XML to BibTeX conversion webtool for ORCID and related research systems.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "sanitize:fixture": "tsx scripts/sanitize-lattes-fixture.ts source/0645206667083920.xml fixtures/lattes/real/sanitized-lattes.xml"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cecil-ia-labs/lattes2orcid.git"
  },
  "keywords": [
    "lattes",
    "orcid",
    "bibtex",
    "react",
    "vite",
    "xml"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/cecil-ia-labs/lattes2orcid/issues"
  },
  "homepage": "https://cecil-ia-labs.github.io/lattes2orcid/",
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "styled-components": "^6.1.19"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@vitejs/plugin-react": "^6.0.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.8.1",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@types/styled-components": "^5.1.34",
    "eslint": "^9.38.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^27.0.1",
    "playwright": "^1.56.1",
    "tsx": "^4.20.6",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
